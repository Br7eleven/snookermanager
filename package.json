{
  "name": "cue-club-manager",
  "private": true,
  "version": "1.0.0",
  "description": "Snooker and billiards club management system",
  "author": "Cue Club Manager",
  "type": "module",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"cross-env NODE_ENV=development vite --port 5173\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder",
    "db:reset": "node scripts/reset-db.js",
    "postinstall": "@electron/rebuild || echo 'Warning: electron-rebuild failed. Install Visual Studio Build Tools if using native modules.'",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.cueclub.manager",
    "productName": "Cue Club Manager",
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "electron-store": "^11.0.2",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0",
    "wait-on": "^9.0.5",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "33.4.11",
    "electron-builder": "^26.8.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron-rebuild": "^3.2.9",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10"
  }
}
